# =============================================================================
# Oil Pulse Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# --- Reddit API (create an app at https://www.reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=oil-pulse-bot/0.1

# --- Airflow ---
AIRFLOW_UID=50000

# --- Project paths (override only if you change the folder layout) ---
DATA_DIR=./data
MODELS_DIR=./models
